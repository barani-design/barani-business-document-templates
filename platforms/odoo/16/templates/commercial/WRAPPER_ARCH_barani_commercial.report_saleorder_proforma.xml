<t t-name="barani_commercial.report_saleorder_proforma">
  <t t-call="web.html_container">
    <t t-foreach="docs" t-as="doc">
      <t t-set="barani_is_proforma" t-value="True"/>
      <t t-set="barani_show_payment_band" t-value="True"/>
      <t t-call="barani_commercial.report_saleorder_document" t-lang="doc.partner_id.lang or user.lang"/>
    </t>
  </t>
</t>
